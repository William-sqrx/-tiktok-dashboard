# --- TikTok app credentials (from https://developers.tiktok.com) ---
# Create an app, add the "Login Kit" product, then copy these from the app's settings.
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a Redirect URI you register in the TikTok app settings.
TIKTOK_REDIRECT_URI=http://localhost:8000/api/auth/tiktok/callback

# Scopes to request. Start with these three (available in sandbox).
TIKTOK_SCOPES=user.info.basic,user.info.stats,video.list

# --- Local app config ---
# Where the React app runs. Used to redirect back after login and for CORS.
FRONTEND_URL=http://localhost:5173

# SQLite by default. Swap for a Postgres URL later if you want.
DATABASE_URL=sqlite:///./tiktok_dashboard.db

# Encrypts the OAuth tokens at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=paste_a_generated_fernet_key_here

# Password gate for the whole dashboard. Anyone visiting must enter this before
# they can see or use the site. Leave empty to disable the gate entirely.
DASHBOARD_PASSWORD=william
